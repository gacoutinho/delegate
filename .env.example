# Copie para .env.local e preencha.
# Chave da API da Anthropic — usada pelo Claude Agent SDK para executar os agentes.
# Pegue em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# (Opcional) Modelo padrão quando o agente não define um.
AGENT_FORGE_DEFAULT_MODEL=claude-opus-4-8
